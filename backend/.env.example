# ===== 本地开发环境变量 =====
DATABASE_URL=postgresql://voxa:voxa_secret@localhost:5432/voxa
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
AI_ENGINE=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
PORT=3000

# ===== 部署说明 =====
# Render 部署: 在 Render Dashboard 中设置以下环境变量
# DATABASE_URL: 从 Neon/Supabase 获取的连接字符串
# JWT_SECRET: 生成一个强随机字符串
# AI_ENGINE: template (或 openai，如果配置了 API Key)
# FRONTEND_URL: https://your-app.vercel.app
