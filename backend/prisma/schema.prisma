generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== 用户模型 ====================

model User {
  id        String    @id @default(cuid())
  username  String    @unique @db.VarChar(30)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  avatar    String?   @db.VarChar(500)
  bio       String?   @db.VarChar(500)
  role      Role      @default(USER)
  isBot     Boolean   @default(false) @map("is_bot")

  posts       Post[]
  comments    Comment[]
  likes       Like[]
  bookmarks   Bookmark[]
  notifications Notification[]
  bot         Bot?
  conversations ConversationParticipant[]
  sentMessagesList Message[] @relation("MessageSender")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ==================== AI 机器人模型 ====================

model Bot {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(50)
  displayName String   @db.VarChar(50)
  avatar      String?  @db.VarChar(500)
  bio         String?  @db.VarChar(500)
  personality String   @db.Text
  systemPrompt String  @db.Text @map("system_prompt")
  topics      String[] // 内容方向标签
  isActive    Boolean  @default(true) @map("is_active")
  postFrequency String @default("3-5") @map("post_frequency") // 每天发帖频率
  commentFrequency String @default("10-20") @map("comment_frequency") // 每天评论频率
  autoReply   Boolean  @default(true) @map("auto_reply") // 被评论/点赞自动回复
  autoMessage Boolean  @default(true) @map("auto_message") // 私信自动回复

  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rssSources  RssSource[]
  botLogs     BotLog[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("bots")
}

// ==================== RSS 源模型 ====================

model RssSource {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  url         String   @db.VarChar(500)
  siteUrl     String?  @db.VarChar(500) @map("site_url")
  description String?  @db.VarChar(500)
  language    String   @default("zh") @db.VarChar(10)
  isActive    Boolean  @default(true) @map("is_active")
  lastFetched DateTime? @map("last_fetched")

  botId       String   @map("bot_id")
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rss_sources")
}

// ==================== Bot 操作日志 ====================

model BotLog {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(50) // POST_CREATED, COMMENT_CREATED, REPLY_SENT, MESSAGE_SENT
  targetType String? @db.VarChar(20) @map("target_type") // post, comment, message
  targetId  String?  @map("target_id")
  metadata  Json?    // 额外信息

  botId     String   @map("bot_id")
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([botId])
  @@index([action])
  @@index([createdAt])
  @@map("bot_logs")
}

// ==================== 私信会话模型 ====================

model Conversation {
  id        String   @id @default(cuid())
  type      ConversationType @default(DIRECT)

  participants ConversationParticipant[]

  messages   Message[]

  lastMessageAt DateTime @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("conversations")
}

enum ConversationType {
  DIRECT // 一对一
}

// ==================== 会话参与者模型 ====================

model ConversationParticipant {
  id             String       @id @default(cuid())
  lastReadAt     DateTime?    @map("last_read_at")

  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

// ==================== 私信消息模型 ====================

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  isRead         Boolean      @default(false) @map("is_read")

  senderId       String       @map("sender_id")
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([senderId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ==================== 分类模型 ====================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(60)
  description String?  @db.VarChar(200)
  icon        String?  @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")

  posts       Post[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

// ==================== 标签模型 ====================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(30)
  slug      String   @unique @db.VarChar(40)

  posts     PostTag[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tags")
}

// ==================== 帖子模型 ====================

model Post {
  id         String    @id @default(cuid())
  title      String    @db.VarChar(200)
  content    String    @db.Text
  slug       String    @unique @db.VarChar(250)
  isPinned   Boolean   @default(false) @map("is_pinned")
  isLocked   Boolean   @default(false) @map("is_locked")
  viewCount  Int       @default(0) @map("view_count")
  sourceUrl  String?   @db.VarChar(500) @map("source_url") // RSS 来源链接

  authorId   String    @map("author_id")
  categoryId String?   @map("category_id")

  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  comments   Comment[]
  tags       PostTag[]
  likes      Like[]
  bookmarks  Bookmark[]

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("posts")
}

// ==================== 评论模型 ====================

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text

  authorId  String   @map("author_id")
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
  @@map("comments")
}

// ==================== 帖子-标签关联 ====================

model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ==================== 点赞模型 ====================

model Like {
  id        String   @id @default(cuid())

  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([userId])
  @@map("likes")
}

// ==================== 收藏模型 ====================

model Bookmark {
  id        String   @id @default(cuid())

  userId    String   @map("user_id")
  postId    String   @map("post_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@index([userId])
  @@map("bookmarks")
}

// ==================== 通知模型 ====================

model Notification {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(50) // COMMENT_REPLY, POST_LIKE, COMMENT_LIKE, NEW_MESSAGE, SYSTEM
  title     String   @db.VarChar(200)
  content   String   @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
